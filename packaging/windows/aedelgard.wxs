<?xml version="1.0" encoding="UTF-8"?>
<!--
  WiX v4 authoring for the Aedelgard body Windows installer (.msi).

  This turns the PyInstaller onedir output (dist/aedelgard-body/) into a proper
  Windows install:
    * installs under Program Files\Aedelgard
    * Start Menu shortcut "Aedelgard Body" (launches the bodiless tray launcher,
      which opens the browser to the local Tower UI / first-run /setup)
    * registers in Add/Remove Programs with a clean uninstall
    * per-machine install, upgrade-aware (same UpgradeCode across versions)

  The harvested file list (the hundreds of files PyInstaller emits, including the
  bundled 167MB ONNX embedding model) is generated at build time by the WiX v4
  <Files> auto-harvest element - we do NOT hand-list them. PayloadDir is supplied
  as a bind path (-b PayloadDir=...) by build_msi.ps1.

  Version is injected at build time via the ProductVersion preprocessor var.
-->
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:util="http://wixtoolset.org/schemas/v4/wxs/util">
  <Package
      Name="Aedelgard Body"
      Manufacturer="Millenion AB"
      Version="$(var.ProductVersion)"
      UpgradeCode="b7e6a4c2-9d31-4f8a-8c2e-1a5d3f0b9c44"
      Scope="perMachine"
      Compressed="yes">

    <!-- Block downgrades, auto-remove older versions on upgrade. Schedule the
         removal of the prior version AFTER InstallInitialize so the old files
         are gone before the new ones land (cleaner than the default late
         removal, and avoids file-in-use churn on the shared exe). -->
    <MajorUpgrade
        Schedule="afterInstallInitialize"
        DowngradeErrorMessage="A newer version of Aedelgard Body is already installed." />

    <MediaTemplate EmbedCab="yes" />

    <!-- Never demand a reboot for a re-install over the running body. The only
         lock is our own process (the localhost app), which CloseApplication
         terminates; once it is gone the file copy succeeds with no reboot.
         REBOOT=ReallySuppress suppresses BOTH the mid-install FilesInUse
         "a reboot may be required" path and the end-of-install reboot prompt.
         CloseApplication uses a HARD terminate (CloseMessage=no) because the
         body has no Win32 message pump to answer WM_CLOSE/WM_QUERYENDSESSION —
         asking politely just hung the installer waiting for an ack that never
         came. NOTE: do NOT add MSIRESTARTMANAGERCONTROL=Disable here — it
         removes RestartManager's safety valve and, with any close wait, wedges
         the install. -->
    <Property Id="REBOOT" Value="ReallySuppress" />

    <!-- Add/Remove Programs metadata. -->
    <Property Id="ARPCOMMENTS" Value="Your Aedelgard mind, running locally on your own machine." />
    <!-- Always-on default ON. Override at install with AEDELGARD_AUTOSTART=0. -->
    <Property Id="AEDELGARD_AUTOSTART" Value="1" />
    <Property Id="ARPURLINFOABOUT" Value="https://aedelgard.com" />
    <Icon Id="AedelgardIcon" SourceFile="packaging\windows\aedelgard.ico" />
    <Property Id="ARPPRODUCTICON" Value="AedelgardIcon" />

    <!-- Install tree: Program Files\Aedelgard\ -->
    <StandardDirectory Id="ProgramFiles64Folder">
      <Directory Id="INSTALLFOLDER" Name="Aedelgard" />
    </StandardDirectory>

    <!-- Reinstall-over-running guard. The body holds port 8080 and locks
         aedelgard-body.exe, so a reinstall would hit 'Files in Use'. We do NOT
         use util:CloseApplication: even with CloseMessage="no" it enumerates
         windows and can surface a RestartManager dialog that HANGS when REBOOT
         is suppressed (the body has no message pump to acknowledge a close).
         Instead a deferred taskkill /F hard-kills the process unconditionally
         BEFORE InstallValidate — no dialog, no RestartManager negotiation.
         /IM matches by image name; the task self-restart can only re-launch
         AFTER file copy, which is fine. Return="ignore": a not-running body
         (taskkill exit 128) must not fail the install. -->
    <!-- IMMEDIATE kill, runs BEFORE InstallValidate. Immediate actions need no
         transaction (so no error 2762) and run early enough that the process is
         already gone when files-in-use detection runs -> the "close the app"
         dialog never appears. The body runs in the user context (/RL LIMITED),
         so an impersonated user-context taskkill reaches it. Return=ignore:
         a not-running body (taskkill exit 128) must not fail the install. -->
    <CustomAction Id="KillRunningBodyNow"
                  Directory="INSTALLFOLDER"
                  ExeCommand="&quot;[System64Folder]taskkill.exe&quot; /F /IM aedelgard-body.exe"
                  Execute="immediate" Return="ignore" Impersonate="yes" />

    <!-- DEFERRED kill, runs inside the transaction just before file copy, as a
         backstop in case the body respawned (e.g. its logon task) between the
         immediate kill and file write. Runs elevated (Impersonate=no). -->
    <SetProperty Id="KillRunningBody"
                 Value="&quot;[System64Folder]taskkill.exe&quot; /F /IM aedelgard-body.exe"
                 Sequence="execute" Before="KillRunningBody" />
    <CustomAction Id="KillRunningBody"
                  BinaryRef="Wix4UtilCA_X64"
                  DllEntry="WixQuietExec64"
                  Execute="deferred" Return="ignore" Impersonate="no" />

    <!-- Start Menu folder + shortcut. -->
    <StandardDirectory Id="ProgramMenuFolder">
      <Directory Id="AppShortcutFolder" Name="Aedelgard">
        <Component Id="StartMenuShortcut" Guid="*">
          <Shortcut
              Id="BodyShortcut"
              Name="Aedelgard Body"
              Description="Your local Aedelgard mind"
              Target="[INSTALLFOLDER]aedelgard-body.exe"
              WorkingDirectory="INSTALLFOLDER"
              Icon="AedelgardIcon" />
          <RemoveFolder Id="RemoveAppShortcutFolder" On="uninstall" />
          <RegistryValue
              Root="HKCU"
              Key="Software\Aedelgard\Body"
              Name="installed"
              Type="integer"
              Value="1"
              KeyPath="yes" />
          <!-- Always-on opt-in marker. Default ON: the body self-registers a
               per-user logon Scheduled Task on first manual launch when this is
               1 (SPEC_always_on_logon.md). Set to 0 to keep on-demand only. -->
          <RegistryValue
              Root="HKCU"
              Key="Software\Aedelgard\Body"
              Name="autostart"
              Type="integer"
              Value="[AEDELGARD_AUTOSTART]" />
        </Component>
      </Directory>
    </StandardDirectory>

    <!-- The big payload: every PyInstaller file (incl. the bundled 167MB ONNX
         embedding model). In WiX v4 the <Files> harvest element lives inside a
         <ComponentGroup> in a sibling <Fragment>; the <Feature> pulls it in by
         reference. (Files-in-Feature -> WIX0005; Files-in-bare-ComponentGroup
         without Directory also fails. This is the shape that actually builds.)
         PayloadDir is supplied as a bind path (-b PayloadDir=...) by build_msi.ps1. -->
    <Feature Id="Main" Title="Aedelgard Body" Level="1">
      <ComponentGroupRef Id="PayloadFiles" />
      <ComponentRef Id="StartMenuShortcut" />
    </Feature>


    <!-- On uninstall, remove the per-user logon task (the body created it from
         the user context; we tear it down here). The MIND in %APPDATA% is
         PRESERVED — never destroy a user's memory on uninstall. quiet/ignore-
         errors: a missing task must not fail the uninstall. -->
    <SetProperty Id="RemoveLogonTask"
                 Value="&quot;[System64Folder]schtasks.exe&quot; /Delete /TN Aedelgard\Body /F"
                 Sequence="execute" Before="RemoveLogonTask" />
    <CustomAction Id="RemoveLogonTask"
                  BinaryRef="Wix4UtilCA_X64"
                  DllEntry="WixQuietExec64"
                  Execute="deferred" Return="ignore" Impersonate="no" />
    <InstallExecuteSequence>
      <!-- TWO-STAGE reinstall-over-running guard, no dialog, no hang, no 2762:
           (1) KillRunningBodyNow — IMMEDIATE, Before InstallValidate. Immediate
               actions need no transaction (no 2762) and run early enough that
               the body is already dead when files-in-use DETECTION runs, so the
               "close the application" dialog never appears. Impersonated, so it
               reaches the user-context body (/RL LIMITED).
           (2) KillRunningBody — DEFERRED, Before InstallFiles. Elevated
               backstop: kills again inside the transaction in case the logon
               task respawned the body between (1) and file copy.
           We deliberately do NOT use util:CloseApplication — its window
           enumeration + RestartManager path HUNG the installer when REBOOT was
           suppressed (the body has no message pump to ack a close). -->
      <Custom Action="KillRunningBodyNow" Before="InstallValidate" Condition="NOT REMOVE=&quot;ALL&quot;" />
      <Custom Action="KillRunningBody" Before="InstallFiles" Condition="NOT REMOVE=&quot;ALL&quot;" />
      <Custom Action="RemoveLogonTask" Before="RemoveFiles" Condition="REMOVE=&quot;ALL&quot;" />
    </InstallExecuteSequence>
  </Package>

  <!-- A Fragment is a sibling of Package in WiX v4. The Files element harvests
       the whole PayloadDir at build time, rooted at INSTALLFOLDER. -->
  <Fragment>
    <ComponentGroup Id="PayloadFiles" Directory="INSTALLFOLDER">
      <Files Include="!(bindpath.PayloadDir)\**" />
    </ComponentGroup>
  </Fragment>
</Wix>
