# === Required ===
ANTHROPIC_API_KEY=sk-ant-...
DISCORD_BOT_TOKEN=your-discord-bot-token

# === Discord Config ===
# Your own Discord user ID (right-click your name → Copy User ID with Developer Mode on)
DISCORD_AUTHORIZED_USER_ID=your-discord-user-id
DISCORD_CHANNEL_ID=your-channel-id

# === Tower UI ===
# SECURITY: Bind to 127.0.0.1 (localhost only) unless you have authentication in front of it.
# The Tower UI has no built-in auth — if bound to 0.0.0.0 on a public server, anyone
# who can reach the port can talk to your agent. Use an SSH tunnel or reverse proxy with auth.
TOWER_HOST=127.0.0.1
TOWER_PORT=8080
# Change this to a long random string in production
TOWER_SECRET_KEY=change-me-to-something-random

# === AWS (optional - uses instance role if on EC2) ===
AWS_REGION=eu-north-1
# Leave AWS_PROFILE blank when using an EC2 instance role — setting it breaks the AWS CLI
AWS_PROFILE=

# === Agent Behavior ===
# Model — cost vs. capability tradeoff:
#   claude-opus-4-6    $15/$75 per MTok (cache read: $1.50/MTok)  — highest capability
#   claude-sonnet-4-6  $3/$15 per MTok  (cache read: $0.30/MTok)  — great balance, lower cache minimum
#   claude-haiku-4-5   $0.80/$4 per MTok (cache read: $0.08/MTok) — cheapest, good for automation
#
# Prompt caching is always active. On a warm cache the stable system prompt (SOUL.md,
# MEMORY.md, identity files) is read at 10% of normal input cost, which cuts per-call
# spend dramatically for context-heavy agents. Use /status in Discord to see live token numbers.
AGENT_MODEL=claude-opus-4-6

# Max output tokens per API call. 8192 is a good balance:
#   - Low enough to keep per-call output cost reasonable
#   - High enough that the max_tokens retry path rarely triggers
AGENT_MAX_TOKENS=8192

DAILY_COST_LIMIT_USD=5.00

# === Memory Palace (MemPalace) — all optional ===
# The harness loads mempalace lazily; if it's not installed, palace tools
# return [palace unavailable] and everything else runs normally. To enable:
#   pip install -r requirements.txt  (includes mempalace>=3.3.2,<3.4)
#   cp mempalace.yaml.example mempalace.yaml
#   mempalace init                   (creates ~/.mempalace/)
#   mempalace mine .                 (seeds the palace from your repo)
#
# Palace directory — read by the MemPalace library itself (not the harness).
# See https://github.com/MemPalace/mempalace for the library's own docs.
# MEMPALACE_PATH=~/.mempalace/palace
#
# Where archived conversations + pre-compaction tool_results land before
# being mined into the palace.
# PALACE_ARCHIVE_ROOT=~/.mempalace/archive
#
# Cached wake-up snapshot file — regenerated after each mine.
# PALACE_WAKE_UP_FILE=~/.mempalace/wake_up.md
#
# Set to 0 to disable injection of the wake-up snapshot into the dynamic
# system-prompt block. Recovers a small per-call token overhead if budget
# is tight. Default: 1 (enabled).
# PALACE_WAKE_UP_INJECT=1
